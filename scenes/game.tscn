[sub_resource type="TileSet" id="TileSet_fc0e3"]
physics_layer_0/collision_layer = 1
custom_data_layer_0/name = "digable"
custom_data_layer_0/type = 1
sources/0 = SubResource("TileSetAtlasSource_feb5d")

[sub_resource type="GDScript" id="GDScript_lbhrr"]
script/source = "extends TileMapLayer

var tilemap = self

const DIAMOND = preload(\"uid://xqjxvxnbggem\")
func spawn_diamond(tile_pos):
	var diamond = DIAMOND.instantiate()
	
	var world_pos = map_to_local(tile_pos)
	diamond.global_position = to_global(world_pos)
	get_tree().current_scene.add_child(diamond)
	





func _process(delta):

	
	
	var mouse_pos = get_global_mouse_position()
	var local_mouse = to_local(mouse_pos)
	var tile_pos = local_to_map(local_mouse)
	mouse_pos = get_global_mouse_position()
	var tile = local_to_map(to_local(mouse_pos))
	if (Input.is_action_just_pressed(\"place\")):
		
		set_cell(tile, 0, Vector2i(2 ,0))
	if (Input.is_action_just_pressed(\"destroy\")):
		
		var local_mouse_pos = to_local(mouse_pos)
		tile_pos = local_to_map(local_mouse)
		var source_id = get_cell_source_id(tile_pos)
		var atlas_coords = get_cell_atlas_coords(tile_pos)
		
		print(\"source:\", source_id, \"Atlas:\", atlas_coords)
		
		
		if source_id == 0 and atlas_coords == Vector2i(2, 3):
			spawn_diamond(tile_pos)
		if source_id != -1:
			set_cell(tile_pos, -1)

	
	
	
"

